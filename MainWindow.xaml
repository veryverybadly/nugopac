<Window x:Class="NugopacEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="nugopac // editor v1.1" Height="650" Width="1050"
        Background="#050505" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.Column="0" Background="#0A0A0A" BorderBrush="#1A1A1A" BorderThickness="0,0,1,0">
            <StackPanel Margin="15">
                <TextBlock Text="nugopac 1.1" Foreground="#32cd32" FontSize="24" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBlock Text="neural overdose edition" Foreground="#7000ff" FontSize="10" Margin="0,0,0,25" Opacity="0.6"/>
                <Button Content="open file" Click="Open_Click" Style="{StaticResource ToolBtn}"/>
                <Separator Background="#1A1A1A" Margin="0,15"/>
                <Button Content="grayscale" Click="Gray_Click" Style="{StaticResource ToolBtn}"/>
                <Button Content="invert" Click="Invert_Click" Style="{StaticResource ToolBtn}"/>
                <Button Content="sepia vibe" Click="Sepia_Click" Style="{StaticResource ToolBtn}"/>
                <Button Content="pixelate" Click="Pixel_Click" Style="{StaticResource ToolBtn}"/>
                <Button Content="save as png" Click="Save_Click" Margin="0,40,0,0" 
                        Background="#32cd32" Foreground="Black" FontWeight="Bold" Height="40"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="0" Grid.Column="1" Background="#000">
            <Image x:Name="MainImage" Margin="30" Stretch="Uniform"/>
        </Grid>

        <StatusBar Grid.Row="1" Grid.ColumnSpan="2" Background="#0A0A0A" BorderBrush="#1A1A1A" BorderThickness="0,1,0,0">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="ready for overdose" Foreground="#32cd32" FontSize="10" Margin="10,0"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>